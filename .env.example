# Discord Bot Token
MUSIC_DISCORD_TOKEN=your_discord_bot_token_here

# Lavalink Node Configuration
LAVALINK_HOST=lavalink.triniumhost.com
LAVALINK_PORT=4333
LAVALINK_PASSWORD=free
LAVALINK_SECURE=false

# MongoDB connection string (Optional - falls back to local sqlite if not provided)
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB_NAME=music_bot_db

# Guild IDs to sync slash commands to instantly (Optional, separate with commas)
# MUSIC_GUILD_IDS=guild_id_1,guild_id_2

# Prefix for prefix commands (if any)
MUSIC_COMMAND_PREFIX=!
